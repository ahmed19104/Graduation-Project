<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Ather - Explore Ancient Egypt</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

    <style>
        /* --- Root Variables --- */
        :root {
            --primary: #0e7490;
            --primary-dark: #0c4a5c;
            --primary-light: #22d3ee;
            --accent: #d97706;
            --accent-light: #fbbf24;
            --grad-gold: linear-gradient(135deg, #f09433 0%, #e6683c 25%, #dc2743 50%, #cc2366 75%, #bc1888 100%);
            --grad-text: linear-gradient(135deg, #f59e0b 0%, #d97706 50%, #92400e 100%);
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --bg-glass: rgba(255, 255, 255, 0.85);
            --bg-input: #f1f5f9;
            --text-main: #1e293b;
            --text-muted: #64748b;
            --border-color: rgba(0, 0, 0, 0.08);
            --shadow-soft: 0 4px 20px -2px rgba(0,0,0,0.05);
            --shadow-float: 0 10px 30px -5px rgba(0,0,0,0.1);
        }

        html.dark {
            --bg-body: #0f172a;
            --bg-card: #1e293b;
            --bg-glass: rgba(15, 23, 42, 0.85);
            --bg-input: #334155;
            --text-main: #f1f5f9;
            --text-muted: #94a3b8;
            --border-color: rgba(255, 255, 255, 0.08);
            --shadow-soft: 0 4px 20px -2px rgba(0,0,0,0.4);
            --shadow-float: 0 10px 30px -5px rgba(0,0,0,0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: var(--bg-body);
            color: var(--text-main);
            transition: 0.3s;
            padding-bottom: 80px;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        button {
            border: none;
            background: none;
            cursor: pointer;
            font-family: inherit;
        }

        img, video {
            max-width: 100%;
            display: block;
        }

        .text-gradient {
            background: var(--grad-text);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hidden {
            display: none !important;
        }

        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }

        ::-webkit-scrollbar-track {
            background: transparent;
        }

        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }

        html.dark ::-webkit-scrollbar-thumb {
            background: #475569;
        }

        .scroll-hide::-webkit-scrollbar {
            display: none;
        }

        .scroll-hide {
            scrollbar-width: none;
            -ms-overflow-style: none;
        }

        /* --- Navbar --- */
        .glass {
            background: var(--bg-glass);
            backdrop-filter: blur(16px);
            border-bottom: 1px solid var(--border-color);
        }

        .nav-desktop {
            position: sticky;
            top: 0;
            z-index: 100;
            transition: all 0.3s;
        }

        .nav-container {
            max-width: 1280px;
            margin: 0 auto;
            padding: 0 24px;
            height: 70px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 800;
            font-size: 1.5rem;
        }

        .nav-menu {
            display: flex;
            gap: 32px;
            align-items: center;
        }

        .nav-item {
            font-weight: 600;
            color: var(--text-muted);
            transition: color 0.2s;
            position: relative;
        }

            .nav-item:hover, .nav-item.active {
                color: var(--primary);
            }

        .auth-actions {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .btn-outline {
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 700;
            transition: 0.2s;
        }

            .btn-outline:hover {
                background: var(--primary);
                color: white;
            }

        .btn-primary {
            background: var(--primary);
            color: white;
            padding: 8px 20px;
            border-radius: 50px;
            font-weight: 700;
            transition: 0.2s;
            box-shadow: var(--shadow-btn);
        }

        .profile-ring {
            width: 42px;
            height: 42px;
            padding: 2px;
            border-radius: 50%;
            background: var(--grad-gold);
        }

        .profile-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid var(--bg-body);
        }

        .notification-dot {
            position: absolute;
            top: 0;
            right: -2px;
            width: 8px;
            height: 8px;
            background-color: #ef4444;
            border-radius: 50%;
            border: 2px solid var(--bg-body);
        }

        /* --- Hero Section --- */
        .hero-section {
            position: relative;
            height: 75vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: -70px;
            overflow: hidden;
        }

        .hero-bg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: -1;
        }

        .hero-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, rgba(0,0,0,0.5) 0%, rgba(0,0,0,0.2) 50%, var(--bg-body) 100%);
            z-index: 0;
        }

        .hero-content {
            position: relative;
            z-index: 10;
            text-align: center;
            width: 100%;
            max-width: 800px;
            padding: 0 20px;
            padding-top: 60px;
        }

        .hero-title {
            font-size: clamp(2.5rem, 5vw, 4.5rem);
            font-weight: 800;
            line-height: 1.1;
            color: white;
            text-shadow: 0 4px 20px rgba(0,0,0,0.3);
            margin-bottom: 20px;
        }

        .search-container {
            background: var(--bg-card);
            padding: 8px;
            border-radius: 50px;
            box-shadow: var(--shadow-float);
            display: flex;
            width: 100%;
            max-width: 700px;
            margin: 0 auto;
        }

        .search-group {
            display: flex;
            align-items: center;
            padding: 12px 24px;
            flex: 1;
        }

            .search-group input {
                width: 100%;
                border: none;
                outline: none;
                background: transparent;
                font-size: 1rem;
                color: var(--text-main);
            }

        .btn-search {
            background: var(--primary);
            color: white;
            padding: 12px 32px;
            border-radius: 50px;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* --- Main Content --- */
        .main-wrapper {
            max-width: 1280px;
            margin: -40px auto 0;
            padding: 0 20px 40px;
            position: relative;
            z-index: 20;
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-bottom: 20px;
            margin-top: 40px;
        }

        .section-title {
            font-size: 1.5rem;
            font-weight: 800;
        }

        .link-more {
            color: var(--primary);
            font-size: 0.95rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* --- Stories --- */
        .stories-container {
            display: flex;
            gap: 16px;
            overflow-x: auto;
            padding-bottom: 12px;
        }

        .story-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            flex-shrink: 0;
            cursor: pointer;
            width: 72px;
            position: relative;
        }

        .story-ring {
            width: 72px;
            height: 72px;
            border-radius: 50%;
            padding: 3px;
            background: var(--grad-gold);
            transition: transform 0.2s;
        }

            .story-ring.viewed {
                background: #cbd5e1;
            }

        html.dark .story-ring.viewed {
            background: #475569;
        }

        .story-ring:active {
            transform: scale(0.95);
        }

        .story-ring img {
            width: 100%;
            height: 100%;
            border-radius: 50%;
            object-fit: cover;
            border: 3px solid var(--bg-body);
        }

        .story-add {
            background: var(--border-color);
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .story-add img {
                border: none;
                opacity: 0.7;
            }

        .add-icon {
            position: absolute;
            bottom: 20px;
            right: 0;
            background: var(--primary);
            color: white;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--bg-body);
            font-weight: bold;
        }

        .story-name {
            font-size: 0.75rem;
            font-weight: 600;
            text-align: center;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            width: 100%;
        }

        /* --- Grids --- */
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }

        .place-card {
            background: var(--bg-card);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: var(--shadow-soft);
            border: 1px solid var(--border-color);
            transition: transform 0.3s;
            cursor: pointer;
        }

            .place-card:hover {
                transform: translateY(-8px);
                box-shadow: var(--shadow-float);
            }

        .card-img-wrap {
            position: relative;
            height: 200px;
        }

            .card-img-wrap img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        .btn-fav {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,0.3);
            backdrop-filter: blur(4px);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            transition: 0.2s;
            z-index: 10;
        }

            .btn-fav.loved {
                color: #ef4444;
                background: white;
            }

                .btn-fav.loved .material-symbols-rounded {
                    font-variation-settings: 'FILL' 1;
                }

        .card-body {
            padding: 20px;
        }

        .card-title {
            font-size: 1.1rem;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .location {
            font-size: 0.85rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .gov-card {
            position: relative;
            border-radius: 20px;
            overflow: hidden;
            height: 150px;
            cursor: pointer;
            transition: 0.3s;
        }

            .gov-card img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.5s;
            }

            .gov-card:hover img {
                transform: scale(1.1);
            }

        .gov-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            display: flex;
            align-items: flex-end;
            padding: 16px;
        }

        .gov-title {
            color: white;
            font-weight: 800;
            font-size: 1.2rem;
            text-shadow: 0 2px 4px rgba(0,0,0,0.5);
        }

        .loader-text {
            text-align: center;
            color: var(--text-muted);
            padding: 20px;
            width: 100%;
            font-size: 0.9rem;
        }

        /* --- Modals --- */
        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(4px);
            z-index: 1000;
            display: flex;
            align-items: center;
            justify-content: center;
            opacity: 0;
            pointer-events: none;
            transition: 0.3s;
        }

            .modal-overlay.active {
                opacity: 1;
                pointer-events: auto;
            }

        .modal-content {
            background: var(--bg-card);
            width: 100%;
            max-width: 450px;
            border-radius: 20px;
            padding: 24px;
            transform: translateY(20px);
            transition: 0.3s;
        }

        .modal-overlay.active .modal-content {
            transform: translateY(0);
        }

        .input-wrapper {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 16px;
        }

        .modal-input {
            width: 100%;
            padding: 12px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: var(--bg-input);
            color: var(--text-main);
            font-family: inherit;
            outline: none;
        }

        /* --- Story Viewer --- */
        .story-viewer {
            position: fixed;
            inset: 0;
            background: #000;
            z-index: 2000;
            display: flex;
            flex-direction: column;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

            .story-viewer.active {
                opacity: 1;
                pointer-events: auto;
            }

        .story-progress-container {
            position: absolute;
            top: 10px;
            left: 10px;
            right: 10px;
            display: flex;
            gap: 4px;
            z-index: 20;
        }

        .story-progress-segment {
            flex: 1;
            height: 3px;
            background: rgba(255,255,255,0.3);
            border-radius: 5px;
            overflow: hidden;
        }

        .story-progress-fill {
            height: 100%;
            background: white;
            width: 0%;
            transform-origin: left;
        }

        .story-top-bar {
            padding: 24px 16px 16px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            color: white;
            position: absolute;
            top: 0;
            width: 100%;
            background: linear-gradient(to bottom, rgba(0,0,0,0.7), transparent);
            z-index: 10;
        }

        .story-user-info {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .story-user-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
        }

        .nav-zone-left {
            position: absolute;
            top: 80px;
            bottom: 80px;
            left: 0;
            width: 30%;
            z-index: 5;
            cursor: pointer;
        }

        .nav-zone-right {
            position: absolute;
            top: 80px;
            bottom: 80px;
            right: 0;
            width: 70%;
            z-index: 5;
            cursor: pointer;
        }

        .story-media-container {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #111;
            overflow: hidden;
            position: relative;
            height: 100vh;
        }

            .story-media-container img, .story-media-container video {
                width: 100%;
                height: 100%;
                object-fit: contain;
            }

        .story-bottom-bar {
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            position: absolute;
            bottom: 0;
            width: 100%;
            background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
            color: white;
            z-index: 10;
        }

        .btn-love {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            color: white;
        }

            .btn-love .icon {
                font-size: 32px;
                transition: 0.2s;
            }

            .btn-love.loved .icon {
                color: #ef4444;
                font-variation-settings: 'FILL' 1;
            }

        footer {
            background: var(--bg-card);
            border-top: 1px solid var(--border-color);
            padding: 40px 20px;
            text-align: center;
            color: var(--text-muted);
        }

        @media (max-width: 768px) {
            .nav-menu, .auth-actions {
                display: none;
            }

            .search-container {
                flex-direction: column;
                border-radius: 20px;
            }
        }
    </style>
</head>
<body class="light">

    <nav class="nav-desktop glass">
        <div class="nav-container">
            <div class="brand"><span class="material-symbols-rounded icon">pyramid</span> Ather <span class="text-gradient" style="font-size: 1rem; margin-left: 4px;">أثر</span></div>
            <div class="nav-menu">
                <a href="/Frontend/Common/index.html" class="nav-item active">Home</a>
                <a href="/Frontend/Common/explore-places.html" class="nav-item">Explore</a>
                <a href="/Frontend/tourist/create-plan.html" class="nav-item">Planner</a>
            </div>
            <div class="auth-actions" id="authArea">
                <div id="unauthButtons" style="display: flex; gap: 12px;">
                    <a href="/Frontend/Account/login.html" class="btn-outline">Log in</a>
                    <a href="/Frontend/Account/register.html" class="btn-primary">Sign up</a>
                </div>
                <div id="authProfile" class="hidden" style="display: flex; gap: 16px; align-items: center;">
                    <button onclick="toggleTheme()"><span class="material-symbols-rounded" style="color:var(--text-muted)">dark_mode</span></button>
                    <a href="/Frontend/Common/notifications.html" class="nav-item"><span class="material-symbols-rounded">notifications</span><span class="notification-dot"></span></a>
                    <a href="/Frontend/Common/Profile.html"><div class="profile-ring"><img src="https://ui-avatars.com/api/?name=User" class="profile-img"></div></a>
                </div>
            </div>
        </div>
    </nav>

    <section class="hero-section">
        <img src="https://images.unsplash.com/photo-1572252009286-268acec5ca0a?q=80&w=1920&fit=crop" class="hero-bg">
        <div class="hero-overlay"></div>
        <div class="hero-content">
            <h1 class="hero-title">Experience the Magic of <br><span class="text-gradient">Ancient Egypt</span></h1>
            <div class="search-container">
                <div class="search-group">
                    <span class="material-symbols-rounded" style="color: var(--text-muted);">search</span>
                    <input type="text" id="heroSearchInput" placeholder="Where to go?" style="margin-left: 8px;">
                </div>
                <button class="btn-search" onclick="searchFromHero()">
                    Search <span class="material-symbols-rounded">arrow_forward</span>
                </button>
            </div>
        </div>
    </section>

    <main class="main-wrapper">
        <div class="stories-container scroll-hide" id="storiesContainer">
            <div class="story-item" onclick="openAddStoryModal()" id="addStoryBtn" style="display: none;">
                <div class="story-ring story-add" style="background: var(--bg-hover);"><img src="https://ui-avatars.com/api/?name=Me&background=cbd5e1"></div>
                <div class="add-icon">+</div>
                <span class="story-name">Add Story</span>
            </div>
            <div id="storiesLoader" class="loader-text">Loading stories...</div>
        </div>

        <div class="section-header">
            <div><h2 class="section-title">Trending Places</h2></div>
            <a href="explore-places.html" class="link-more">See All <span class="material-symbols-rounded">arrow_forward</span></a>
        </div>
        <div class="card-grid" id="placesContainer"><div style="text-align:center; width:100%; color:var(--text-muted)">Loading...</div></div>

        <div class="section-header" style="margin-top: 40px;">
            <div><h2 class="section-title">Governorates</h2></div>
            <a href="explore-places.html" class="link-more">See All <span class="material-symbols-rounded">arrow_forward</span></a>
        </div>
        <div class="card-grid" id="govsContainer" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));"></div>
    </main>

    <footer>
        <div style="display: flex; justify-content: center; align-items: center; gap: 8px; font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin-bottom: 20px;">
            <span class="material-symbols-rounded" style="color: var(--primary);">pyramid</span> Ather <span style="font-size: 1rem; color: var(--primary);">أثر</span>
        </div>
        <p>© 2026 Ather. All rights reserved.</p>
    </footer>

    <div class="modal-overlay" id="addStoryModal">
        <div class="modal-content">
            <div style="display: flex; justify-content: space-between; margin-bottom: 20px;">
                <h3 style="font-weight: 800;">Create a Story</h3>
                <button onclick="closeAddStoryModal()"><span class="material-symbols-rounded">close</span></button>
            </div>
            <form onsubmit="submitStory(event)">
                <div class="input-wrapper">
                    <label style="font-size: 0.85rem; font-weight: 600;">Media (Image/Video)</label>
                    <input type="file" id="storyMediaModal" class="modal-input" accept="image/*,video/*" required>
                </div>
                <div class="input-wrapper">
                    <label style="font-size: 0.85rem; font-weight: 600;">City</label>
                    <input type="text" id="storyCity" class="modal-input" placeholder="e.g., Luxor" required>
                </div>
                <div class="input-wrapper">
                    <label style="font-size: 0.85rem; font-weight: 600;">Description</label>
                    <textarea id="storyDesc" class="modal-input" placeholder="What's happening?" rows="3" required></textarea>
                </div>
                <button type="submit" class="btn-primary" style="width: 100%; border-radius: 8px; margin-top: 10px;" id="btnSubmitStory">Share Story</button>
            </form>
        </div>
    </div>

    <div class="story-viewer" id="storyViewer">
        <div class="story-progress-container" id="svProgressContainer"></div>

        <div class="story-top-bar">
            <div class="story-user-info">
                <img src="" id="svAvatar" class="story-user-avatar">
                <div>
                    <div style="font-weight: 700; font-size: 0.95rem; text-shadow: 0 1px 3px rgba(0,0,0,0.5);" id="svUserName"></div>
                    <div style="font-size: 0.75rem; color: rgba(255,255,255,0.8); text-shadow: 0 1px 3px rgba(0,0,0,0.5);" id="svCityTime"></div>
                </div>
            </div>
            <button onclick="closeStoryViewer()" style="color: white; z-index: 50;"><span class="material-symbols-rounded" style="font-size: 28px;">close</span></button>
        </div>

        <div class="nav-zone-left" onclick="prevStory()"></div>
        <div class="nav-zone-right" onclick="nextStory()"></div>

        <div class="story-media-container" id="svMediaContainer"></div>

        <div class="story-bottom-bar">
            <div style="flex: 1; margin-right: 16px;">
                <p style="font-size: 0.9rem; text-shadow: 0 1px 3px rgba(0,0,0,0.8); margin-bottom: 4px;" id="svDesc"></p>
                <div style="font-size: 0.8rem; color: rgba(255,255,255,0.7);"><span class="material-symbols-rounded" style="font-size:16px; vertical-align:middle;">visibility</span> <span id="svViews">0</span> Views</div>
            </div>
            <button class="btn-love" id="btnStoryLove" onclick="toggleStoryLove()" style="z-index: 50;">
                <span class="material-symbols-rounded icon" id="iconStoryLove">favorite</span>
                <span id="svLoves" style="font-size: 0.8rem; font-weight: normal;">0</span>
            </button>
        </div>
    </div>

    <script>
        const API = {
            stories: '/api/Stories/active',
            viewStory: (id) => `/api/Stories/${id}/view`,
            loveStory: (id) => `/api/Stories/${id}/love`,
            uploadStory: '/api/Stories/create',
            places: '/api/Places',
            getGovernorates: '/api/Governorates'
        };
        const token = localStorage.getItem('jwtToken');

        // --- Init Auth UI ---
        if (token) {
            document.getElementById('unauthButtons').classList.add('hidden');
            document.getElementById('authProfile').classList.remove('hidden');
            document.getElementById('addStoryBtn').style.display = 'flex';
        }

        // ==========================================
        // 1. Stories Logic
        // ==========================================
        let allStories = [];
        let currentStoryIndex = 0;
        let storyTimer;
        window.activeVideo = null;

        function getLocalViewedStories() {
            const viewed = localStorage.getItem('viewedStoriesCache');
            return viewed ? JSON.parse(viewed) : [];
        }

        async function fetchStories() {
            try {
                const res = await fetch(API.stories, { headers: token ? { 'Authorization': `Bearer ${token}` } : {} });
                if (res.ok) {
                    const result = await res.json();
                    let fetchedStories = result.data || result;

                    const localViewed = getLocalViewedStories();
                    fetchedStories.forEach(s => {
                        if (localViewed.includes(s.storyId) || s.isViewed) s.isViewed = true;
                    });

                    allStories = fetchedStories;
                    renderStoriesList();
                }
            } catch (e) { console.log('Stories API Error.'); }
        }

        function renderStoriesList() {
            const container = document.getElementById('storiesContainer');
            const addBtnHtml = container.firstElementChild.outerHTML;
            container.innerHTML = addBtnHtml;

            allStories.sort((a, b) => (a.isViewed === b.isViewed ? 0 : a.isViewed ? 1 : -1));

            allStories.forEach((s, index) => {
                const avatar = s.userProfileImage || `https://ui-avatars.com/api/?name=${s.userName}`;
                const ringClass = s.isViewed ? 'viewed' : '';
                container.innerHTML += `
                        <div class="story-item" onclick="openStoryViewer(${index})">
                            <div class="story-ring ${ringClass}"><img src="${avatar}"></div>
                            <span class="story-name">${s.userName}</span>
                        </div>`;
            });
            document.getElementById('storiesLoader').style.display = 'none';
        }

        function openAddStoryModal() { document.getElementById('addStoryModal').classList.add('active'); }
        function closeAddStoryModal() { document.getElementById('addStoryModal').classList.remove('active'); }

        async function submitStory(e) {
            e.preventDefault();
            const fileInput = document.getElementById('storyMediaModal');
            if (!fileInput.files.length) return;

            const btn = document.getElementById('btnSubmitStory');
            btn.disabled = true; btn.innerText = "Uploading...";

            const formData = new FormData();
            formData.append('MediaFile', fileInput.files[0]);
            formData.append('City', document.getElementById('storyCity').value);
            formData.append('Description', document.getElementById('storyDesc').value);

            try {
                const res = await fetch(API.uploadStory, {
                    method: 'POST',
                    headers: { 'Authorization': `Bearer ${token}` },
                    body: formData
                });

                const textResponse = await res.text();
                let result = {};
                try { result = JSON.parse(textResponse); }
                catch (err) { result = { isSuccess: false, message: `Server Error: ${res.status}` }; }

                if (res.ok && (result.isSuccess || result.IsSuccess)) {
                    alert("🎉 Story added successfully!");
                    closeAddStoryModal();
                    fetchStories(); // Refresh list without full reload
                } else {
                    let errorMsg = result.message || result.Message || "Unknown error";
                    if (result.errors) errorMsg = JSON.stringify(result.errors);
                    alert("❌ Error: " + errorMsg);
                }
            } catch (err) {
                alert("❌ Connection error.");
            } finally {
                btn.disabled = false; btn.innerText = "Share Story";
                fileInput.value = '';
            }
        }

        function openStoryViewer(index) {
            if (index < 0 || index >= allStories.length) { closeStoryViewer(); return; }
            currentStoryIndex = index;
            const story = allStories[index];

            document.getElementById('svAvatar').src = story.userProfileImage || `https://ui-avatars.com/api/?name=${story.userName}`;
            document.getElementById('svUserName').innerText = story.userName;
            document.getElementById('svCityTime').innerText = story.city || 'Egypt';
            document.getElementById('svDesc').innerText = story.description || '';
            document.getElementById('svViews').innerText = story.viewsCount || 0;
            document.getElementById('svLoves').innerText = story.lovesCount || 0;

            const loveBtn = document.getElementById('btnStoryLove');
            if (story.isLovedByMe) {
                loveBtn.classList.add('loved');
                document.getElementById('iconStoryLove').style.fontVariationSettings = "'FILL' 1";
            } else {
                loveBtn.classList.remove('loved');
                document.getElementById('iconStoryLove').style.fontVariationSettings = "'FILL' 0";
            }

            const progContainer = document.getElementById('svProgressContainer');
            progContainer.innerHTML = allStories.map((_, i) => `
                    <div class="story-progress-segment">
                        <div class="story-progress-fill" style="width: ${i < index ? '100%' : '0%'}"></div>
                    </div>`).join('');

            const currentBar = progContainer.children[index].firstElementChild;
            const mediaBox = document.getElementById('svMediaContainer');
            clearTimeout(storyTimer);

            if (window.activeVideo) {
                window.activeVideo.pause();
                window.activeVideo.removeEventListener('timeupdate', updateVideoProgress);
                window.activeVideo.removeEventListener('ended', onVideoEnd);
            }

            function updateVideoProgress() {
                if (window.activeVideo && window.activeVideo.duration) {
                    const percent = (window.activeVideo.currentTime / window.activeVideo.duration) * 100;
                    currentBar.style.width = `${percent}%`;
                }
            }
            function onVideoEnd() { nextStory(); }

            if (story.mediaType === "Video") {
                mediaBox.innerHTML = `<video id="activeVideo" src="${story.mediaUrl}" autoplay playsinline></video>`;
                window.activeVideo = document.getElementById('activeVideo');
                window.activeVideo.addEventListener('timeupdate', updateVideoProgress);
                window.activeVideo.addEventListener('ended', onVideoEnd);
            } else {
                mediaBox.innerHTML = `<img src="${story.mediaUrl}" style="width:100%; height:100%; object-fit:contain;">`;
                setTimeout(() => {
                    if (currentBar) {
                        currentBar.style.transition = `width 5s linear`;
                        currentBar.style.width = '100%';
                    }
                }, 50);
                storyTimer = setTimeout(() => nextStory(), 5000);
            }

            document.getElementById('storyViewer').classList.add('active');

            if (!story.isViewed) {
                story.isViewed = true;
                const viewedList = getLocalViewedStories();
                if (!viewedList.includes(story.storyId)) {
                    viewedList.push(story.storyId);
                    localStorage.setItem('viewedStoriesCache', JSON.stringify(viewedList));
                }
                if (token) {
                    fetch(API.viewStory(story.storyId), {
                        method: 'POST',
                        headers: { 'Authorization': `Bearer ${token}` }
                    }).catch(err => console.log('View registration failed'));
                }
                renderStoriesList();
            }
        }

        function nextStory() { openStoryViewer(currentStoryIndex + 1); }
        function prevStory() { openStoryViewer(currentStoryIndex - 1); }

        function closeStoryViewer() {
            clearTimeout(storyTimer);
            if (window.activeVideo) {
                window.activeVideo.pause();
            }
            document.getElementById('storyViewer').classList.remove('active');
            document.getElementById('svMediaContainer').innerHTML = '';
        }

        async function toggleStoryLove() {
            if (!token) return alert("Please login.");
            const story = allStories[currentStoryIndex];
            story.isLovedByMe = !story.isLovedByMe;
            story.lovesCount += story.isLovedByMe ? 1 : -1;

            const btn = document.getElementById('btnStoryLove');
            btn.classList.toggle('loved', story.isLovedByMe);
            document.getElementById('iconStoryLove').style.fontVariationSettings = story.isLovedByMe ? "'FILL' 1" : "'FILL' 0";
            document.getElementById('svLoves').innerText = story.lovesCount;

            fetch(API.loveStory(story.storyId), { method: 'POST', headers: { 'Authorization': `Bearer ${token}` } });
        }

        // Close viewer on Escape or outside click
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape' && document.getElementById('storyViewer').classList.contains('active')) {
                closeStoryViewer();
            }
        });
        document.getElementById('storyViewer').addEventListener('click', (e) => {
            if (e.target === document.getElementById('storyViewer')) {
                closeStoryViewer();
            }
        });

        // ==========================================
        // 2. Places & Governorates Logic
        // ==========================================
        async function fetchPlaces() {
            try {
                const res = await fetch(API.places);
                const result = await res.json();
                const data = result.data || result;
                const container = document.getElementById('placesContainer');
                container.innerHTML = '';

                data.slice(0, 4).forEach(p => {
                    const placeId = p.id || p.Id;
                    const placeName = p.name || p.Name;
                    const placeImg = p.mainImageUrl || p.imageUrl || 'https://images.unsplash.com/photo-1539650116574-8efeb43e2750?w=500&fit=crop';

                    container.innerHTML += `
                        <div class="place-card" onclick="window.location.href='place-details.html?id=${placeId}'">
                            <div class="card-img-wrap">
                                <img src="${placeImg}">
                                <button class="btn-fav" onclick="toggleFav(event, this)"><span class="material-symbols-rounded">favorite_border</span></button>
                            </div>
                            <div class="card-body">
                                <h3 class="card-title">${placeName}</h3>
                                <div class="location"><span class="material-symbols-rounded">location_on</span> ${p.city || 'Egypt'}</div>
                            </div>
                        </div>`;
                });
            } catch (e) { console.log('Places API Error'); }
        }

        function toggleFav(e, btn) {
            e.stopPropagation();
            if (!token) return alert("Please Login");
            btn.classList.toggle('loved');
            btn.innerHTML = `<span class="material-symbols-rounded">${btn.classList.contains('loved') ? 'favorite' : 'favorite_border'}</span>`;
        }

        async function fetchGovernorates() {
            try {
                const res = await fetch(API.getGovernorates);
                const result = await res.json();
                const data = result.data || result;
                const container = document.getElementById('govsContainer');
                container.innerHTML = '';

                if (data.length === 0) {
                    container.innerHTML = '<div class="loader-text" style="grid-column: 1 / -1;">No governorates found.</div>';
                    return;
                }

                data.forEach(g => {
                    const govName = g.name || g.Name;
                    const govImg = g.imageUrl || g.ImageUrl || 'https://images.unsplash.com/photo-1539650116574-8efeb43e2750?w=400&fit=crop';
                    container.innerHTML += `
                        <div class="gov-card" onclick="window.location.href='explore-places.html?gov=${encodeURIComponent(govName)}'">
                            <img src="${govImg}">
                            <div class="gov-overlay"><h3 class="gov-title">${govName}</h3></div>
                        </div>`;
                });
            } catch (e) {
                console.log('Governorates API Error, using fallback');
                renderGovsFallback();
            }
        }

        function renderGovsFallback() {
            const govData = [
                { name: "Cairo", img: "https://images.unsplash.com/photo-1539650116574-8efeb43e2750?w=400&fit=crop" },
                { name: "Luxor", img: "https://images.unsplash.com/photo-1572252009286-268acec5ca0a?w=400&fit=crop" },
                { name: "Aswan", img: "https://images.unsplash.com/photo-1518548419970-58e3b4079ab2?w=400&fit=crop" },
                { name: "Alexandria", img: "https://images.unsplash.com/photo-1563604561005-927bb463d11b?w=400&fit=crop" }
            ];
            const container = document.getElementById('govsContainer');
            container.innerHTML = '';
            govData.forEach(g => {
                container.innerHTML += `
                    <div class="gov-card" onclick="window.location.href='explore-places.html?gov=${g.name}'">
                        <img src="${g.img}">
                        <div class="gov-overlay"><h3 class="gov-title">${g.name}</h3></div>
                    </div>`;
            });
        }

        // --- Search Hero Logic ---
        function searchFromHero() {
            const query = document.getElementById('heroSearchInput').value.trim();
            if (query) {
                window.location.href = `explore-places.html?search=${encodeURIComponent(query)}`;
            }
        }

        // --- Init ---
        fetchStories();
        fetchPlaces();
        fetchGovernorates();

        function toggleTheme() {
            document.documentElement.classList.toggle('dark');
            localStorage.setItem('theme', document.documentElement.classList.contains('dark') ? 'dark' : 'light');
        }
        if (localStorage.getItem('theme') === 'dark') document.documentElement.classList.add('dark');

        // Refresh stories when page becomes visible
        document.addEventListener('visibilitychange', () => {
            if (!document.hidden) {
                fetchStories();
            }
        });
    </script>
</body>
</html>