<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
    <title>Login - Ather</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,0,0" />

    <style>
        /* --- Root Variables & Base --- */
        :root {
            --primary: #0e7490;
            --primary-dark: #0c4a5c;
            --primary-light: #22d3ee;
            --accent: #d97706;
            --grad-text: linear-gradient(135deg, #f59e0b 0%, #d97706 50%, #92400e 100%);
            --bg-body: #f8fafc;
            --bg-card: #ffffff;
            --bg-input: #ffffff;
            --bg-hover: #f1f5f9;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --text-placeholder: #94a3b8;
            --border-color: #e2e8f0;
            --shadow-btn: 0 10px 15px -3px rgba(14, 116, 144, 0.3);
            --selection-bg: #0e7490;
            --selection-text: #ffffff;
        }

        html.dark {
            --bg-body: #0f172a;
            --bg-card: #1e293b;
            --bg-input: #1e293b;
            --bg-hover: #334155;
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --text-placeholder: #64748b;
            --border-color: #334155;
            --shadow-btn: 0 10px 15px -3px rgba(0, 0, 0, 0.5);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
        }

        ::selection {
            background: var(--selection-bg);
            color: var(--selection-text);
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            display: flex;
            flex-direction: column;
            height: 100vh;
            overflow: hidden;
            background: var(--bg-body);
            color: var(--text-main);
            transition: background 0.3s, color 0.3s;
        }

        a {
            text-decoration: none;
            color: var(--primary);
            transition: 0.2s;
        }

            a:hover {
                color: var(--primary-dark);
            }

        button {
            border: none;
            background: none;
            cursor: pointer;
            font-family: inherit;
            outline: none;
        }

        img {
            max-width: 100%;
            display: block;
            object-fit: cover;
        }

        .text-gradient {
            background: var(--grad-text);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hidden {
            display: none !important;
        }

        /* --- Split Layout --- */
        .layout-wrapper {
            display: flex;
            width: 100%;
            height: 100%;
            flex-direction: column;
        }

        /* Left Panel */
        .panel-img {
            display: none;
            position: relative;
            overflow: hidden;
            background: #0f172a;
        }

            .panel-img .bg-img {
                position: absolute;
                inset: 0;
                width: 100%;
                height: 100%;
                transition: transform 1s ease-out;
            }

            .panel-img:hover .bg-img {
                transform: scale(1.05);
            }

        .img-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.8), rgba(0,0,0,0.2) 40%, rgba(0,0,0,0.4));
        }

        .img-content {
            position: absolute;
            bottom: 32px;
            left: 32px;
            right: 32px;
            color: white;
            z-index: 10;
        }

        .badge-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 12px;
        }

        .badge-solid {
            background: rgba(14, 116, 144, 0.9);
            color: white;
            font-size: 0.75rem;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 50px;
        }

        .img-title {
            font-size: 2.25rem;
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 8px;
        }

            .img-title span {
                color: var(--primary-light);
            }

        .img-desc {
            color: #e2e8f0;
            font-size: 1rem;
            max-width: 400px;
            line-height: 1.5;
        }

        /* Right Panel */
        .panel-form {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            overflow-y: auto;
            background: var(--bg-body);
            position: relative;
        }

        .form-container {
            width: 100%;
            max-width: 384px;
            display: flex;
            flex-direction: column;
            gap: 24px;
        }

        .btn-theme {
            position: absolute;
            top: 16px;
            right: 16px;
            z-index: 10;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--text-muted);
            transition: 0.2s;
        }

            .btn-theme:hover {
                background: var(--bg-hover);
                color: var(--text-main);
            }

        .form-header {
            text-align: center;
        }

        .icon-logo {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 64px;
            height: 64px;
            border-radius: 16px;
            background: rgba(14, 116, 144, 0.1);
            color: var(--primary);
            margin-bottom: 16px;
        }

            .icon-logo span {
                font-size: 32px;
            }

        .form-brand {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 16px;
        }

        .form-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--text-main);
            letter-spacing: -0.5px;
        }

        .form-subtitle {
            font-size: 0.875rem;
            color: var(--text-muted);
            margin-top: 4px;
        }

        /* Inputs */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .input-label {
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-main);
        }

        .input-wrapper {
            position: relative;
            display: flex;
            align-items: center;
        }

        .input-icon-left {
            position: absolute;
            left: 12px;
            color: var(--text-muted);
            font-size: 20px;
            pointer-events: none;
        }

        .input-icon-right {
            position: absolute;
            right: 12px;
            color: var(--text-muted);
            font-size: 20px;
            cursor: pointer;
            transition: color 0.2s;
        }

            .input-icon-right:hover {
                color: var(--text-main);
            }

        .input-field {
            width: 100%;
            padding: 10px 12px 10px 40px;
            border: 1px solid var(--border-color);
            border-radius: 8px;
            background: var(--bg-input);
            color: var(--text-main);
            font-size: 0.875rem;
            outline: none;
            font-family: inherit;
            transition: all 0.3s;
        }

            .input-field.has-right {
                padding-right: 40px;
            }

            .input-field:focus {
                border-color: var(--primary);
                transform: translateY(-2px);
                box-shadow: 0 10px 20px -10px rgba(14, 116, 144, 0.2);
            }

        .options-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 4px;
        }

        .checkbox-wrap {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .custom-checkbox {
            appearance: none;
            width: 16px;
            height: 16px;
            border: 1px solid #cbd5e1;
            border-radius: 4px;
            cursor: pointer;
            position: relative;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

            .custom-checkbox:checked {
                background: var(--primary);
                border-color: var(--primary);
            }

                .custom-checkbox:checked::after {
                    content: '✓';
                    color: white;
                    font-size: 10px;
                    font-weight: bold;
                    position: absolute;
                }

        .checkbox-label {
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .forgot-link {
            font-size: 0.875rem;
            font-weight: 600;
        }

        .btn-submit {
            width: 100%;
            padding: 12px 16px;
            border-radius: 8px;
            background: var(--primary);
            color: white;
            font-size: 0.875rem;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            box-shadow: var(--shadow-btn);
            transition: all 0.2s;
            margin-top: 8px;
        }

            .btn-submit:hover {
                background: var(--primary-dark);
            }

        .form-footer {
            text-align: center;
            font-size: 0.875rem;
            color: var(--text-muted);
        }

        .secure-badge {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-size: 0.75rem;
            color: var(--text-placeholder);
            margin-top: 8px;
        }

        @media (min-width: 768px) {
            .layout-wrapper {
                flex-direction: row;
            }

            .panel-img {
                display: block;
                width: 50%;
            }

            .panel-form {
                width: 50%;
            }
        }
    </style>
</head>
<body class="light">

    <div class="layout-wrapper">
        <div class="panel-img">
            <img src="https://images.unsplash.com/photo-1572252009286-268acec5ca0a?q=80&w=1000&auto=format&fit=crop" alt="Egypt" class="bg-img">
            <div class="img-overlay"></div>

            <div class="img-content">
                <div class="badge-row">
                    <span class="badge-solid">Welcome Back</span>
                    <span class="badge-glass"><span class="material-symbols-rounded" style="font-size: 14px;">place</span> Luxor</span>
                </div>
                <h2 class="img-title">Uncover <span>Ancient</span> Mysteries</h2>
                <p class="img-desc">Access your AI-powered itineraries and continue your journey with Ather.</p>
            </div>
        </div>

        <div class="panel-form">
            <button id="theme-toggle-login" class="btn-theme">
                <span class="material-symbols-rounded icon-dark">dark_mode</span>
                <span class="material-symbols-rounded icon-light" style="display: none; color: #fbbf24;">light_mode</span>
            </button>

            <div class="form-container">
                <div class="form-header">
                    <div class="form-brand">
                        <span class="material-symbols-rounded icon" style="font-size: 36px; color: var(--primary);">Ather</span>
                    </div>
                    <p class="form-subtitle">Welcome back! Please enter your details.</p>
                </div>

                <form onsubmit="handleLogin(event)">
                    <div style="display: flex; flex-direction: column; gap: 16px;">

                        <div id="errorAlert" class="hidden" style="color: #ef4444; font-size: 0.875rem; text-align: center; background: #fef2f2; padding: 10px; border-radius: 8px; border: 1px solid #fca5a5;"></div>

                        <div class="input-group">
                            <label class="input-label">Email Address</label>
                            <div class="input-wrapper">
                                <span class="material-symbols-rounded input-icon-left">mail_outline</span>
                                <input type="email" id="email" class="input-field" placeholder="name@example.com" required>
                            </div>
                        </div>

                        <div class="input-group">
                            <label class="input-label">Password</label>
                            <div class="input-wrapper">
                                <span class="material-symbols-rounded input-icon-left">lock_outline</span>
                                <input type="password" id="password" class="input-field has-right" placeholder="••••••••" required>
                                <span class="material-symbols-rounded input-icon-right" id="toggle-password">visibility_off</span>
                            </div>
                        </div>

                        <div class="options-row">
                            <label class="checkbox-wrap">
                                <input type="checkbox" class="custom-checkbox">
                                <span class="checkbox-label">Remember me</span>
                            </label>
                            <a href="forgot-password.html" class="forgot-link">Forgot password?</a>
                        </div>

                        <button type="submit" class="btn-submit" id="loginBtn">
                            Login <span class="material-symbols-rounded icon-arrow">arrow_forward</span>
                        </button>
                    </div>
                </form>

                <div>
                    <p class="form-footer">Don't have an account? <a href="register.html">Sign Up</a></p>
                    <p class="form-footer" style="margin-top: 8px;">Account not activated? <a href="request-activation.html">Activate Now</a></p>
                    <div class="secure-badge">
                        <span><span class="material-symbols-rounded" style="font-size: 14px;">lock</span> Secure Login</span>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script>
        // Password Visibility
        const togglePassword = document.getElementById('toggle-password');
        const passwordInput = document.getElementById('password');

        togglePassword.addEventListener('click', function () {
            if (passwordInput.type === 'password') {
                passwordInput.type = 'text';
                this.textContent = 'visibility';
            } else {
                passwordInput.type = 'password';
                this.textContent = 'visibility_off';
            }
        });

        // Theme Toggle
        const html = document.documentElement;
        const toggleThemeBtn = document.getElementById('theme-toggle-login');
        const iconDark = document.querySelector('.icon-dark');
        const iconLight = document.querySelector('.icon-light');

        const savedTheme = localStorage.getItem('theme');
        if (savedTheme === 'dark' || (!savedTheme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
            html.classList.add('dark');
            iconDark.style.display = 'none';
            iconLight.style.display = 'block';
        }

        toggleThemeBtn.addEventListener('click', () => {
            html.classList.toggle('dark');
            if (html.classList.contains('dark')) {
                localStorage.setItem('theme', 'dark');
                iconDark.style.display = 'none';
                iconLight.style.display = 'block';
            } else {
                localStorage.setItem('theme', 'light');
                iconDark.style.display = 'block';
                iconLight.style.display = 'none';
            }
        });

        // Login Logic (API Integration)
        async function handleLogin(e) {
            e.preventDefault();
            const btn = document.getElementById('loginBtn');
            const errorAlert = document.getElementById('errorAlert');
            const email = document.getElementById('email').value;
            const password = passwordInput.value;

            errorAlert.classList.add('hidden');
            btn.innerHTML = '<span class="spinner-grow spinner-grow-sm" role="status" aria-hidden="true" style="width: 1rem; height: 1rem; display: inline-block;"></span> Logging in...';
            btn.disabled = true;

            try {
                const response = await fetch('/api/Account/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: email, password: password })
                });

                const result = await response.json();

                if (response.ok && result.isSuccess) {
                    const token = result.data || result.token;
                    localStorage.setItem('jwtToken', token);

                    if (result.role) {
                        localStorage.setItem('userRole', result.role);
                    }

                    window.location.href = '../common/index.html';
                } else {
                    errorAlert.innerText = result.message || "Invalid Email or Password.";
                    errorAlert.classList.remove('hidden');
                }
            } catch (error) {
                errorAlert.innerText = "Connection error. Please make sure the server is running.";
                errorAlert.classList.remove('hidden');
            } finally {
                btn.innerHTML = 'Login <span class="material-symbols-rounded icon-arrow">arrow_forward</span>';
                btn.disabled = false;
            }
        }

    </script>
</body>
</html>