import { useEffect, useState } from 'react'
import { Link, useParams, useSearchParams } from 'react-router-dom'
import { Calendar, Clock, MapPin, Sparkles, DollarSign } from 'lucide-react'
import { plansApi } from '@/api/plans'
import { Badge, Button, Card, CardSkeleton, useToast } from '@/components/ui'
import { getErrorMessage } from '@/api/axios'
import { formatCurrency } from '@/utils/format'
import type { AiPlanDetails, ManualPlan } from '@/types'

export function PlanDetailPage() {
  const { id } = useParams<{ id: string }>()
  const [searchParams] = useSearchParams()
  const planType = searchParams.get('type') || 'ai'
  const [plan, setPlan] = useState<AiPlanDetails | ManualPlan | null>(null)
  const [isLoading, setIsLoading] = useState(true)
  const { showToast } = useToast()

  useEffect(() => {
    if (!id) return
    
    const loadPlan = async () => {
      setIsLoading(true)
      try {
        if (planType === 'ai') {
          const data = await plansApi.getAiPlanDetails(id)
          setPlan(data)
        } else {
          const plans = await plansApi.getMyManualPlans()
          const found = plans.find(p => p.id === id)
          setPlan(found || null)
        }
      } catch (err) {
        showToast(getErrorMessage(err), 'error')
      } finally {
        setIsLoading(false)
      }
    }
    
    loadPlan()
  }, [id, planType, showToast])

  if (isLoading) return <div className="container mx-auto px-4 py-8"><CardSkeleton /></div>
  if (!plan) return <div className="container mx-auto px-4 py-8 text-center">Plan not found</div>

  const isAi = planType === 'ai'
  const aiPlan = isAi ? plan as AiPlanDetails : null
  const manualPlan = !isAi ? plan as ManualPlan : null

  return (
    <div className="container mx-auto px-4 py-8 max-w-2xl">
      <div className="flex items-start justify-between gap-4 mb-6">
        <div>
          <h1 className="text-2xl font-bold">{plan.name}</h1>
          <div className="flex items-center gap-4 mt-2 text-sm text-slate-500">
            {isAi ? (
              <>
                <span className="flex items-center gap-1">
                  <Calendar className="h-4 w-4" />
                  {aiPlan!.countDay} days
                </span>
                <span className="flex items-center gap-1">
                  <DollarSign className="h-4 w-4" />
                  {formatCurrency(aiPlan!.budget)}
                </span>
              </>
            ) : (
              <span className="flex items-center gap-1">
                <Calendar className="h-4 w-4" />
                Starts: {new Date(manualPlan!.startDate).toLocaleDateString()}
              </span>
            )}
          </div>
        </div>
        <Badge variant={isAi ? 'primary' : 'secondary'} className="flex items-center gap-1">
          {isAi && <Sparkles className="h-3 w-3" />}
          {isAi ? 'AI Plan' : 'Manual Plan'}
        </Badge>
      </div>

      {isAi && aiPlan?.planItinerary && aiPlan.planItinerary.length > 0 ? (
        <div className="space-y-4 mb-8">
          {(() => {
            const grouped = aiPlan.planItinerary.reduce((acc, item) => {
              if (!acc[item.dayNumber]) acc[item.dayNumber] = []
              acc[item.dayNumber].push(item)
              return acc
            }, {} as Record<number, typeof aiPlan.planItinerary>)
            
            return Object.entries(grouped).map(([day, items]) => (
              <Card key={day} className="p-5">
                <h3 className="font-bold text-primary-600 mb-3">Day {day}</h3>
                <div className="space-y-3">
                  {items.map((item, idx) => (
                    <div key={idx} className="flex gap-3 p-3 bg-slate-50 rounded-xl">
                      <div className="flex-shrink-0 w-16 h-16 rounded-lg overflow-hidden">
                        <img 
                          src={item.imageUrl || 'https://placehold.co/100x100?text=No+Image'} 
                          alt={item.placeName}
                          className="w-full h-full object-cover"
                        />
                      </div>
                      <div className="flex-1">
                        <Link to={`/explore/${item.placeId}`} className="font-semibold text-sm hover:text-primary-600">
                          {item.placeName}
                        </Link>
                        <p className="text-xs text-slate-500 mt-1 line-clamp-2">{item.description}</p>
                        <p className="text-xs text-primary-600 mt-1">{formatCurrency(item.ticketPrice)} entry</p>
                      </div>
                    </div>
                  ))}
                </div>
              </Card>
            ))
          })()}
        </div>
      ) : manualPlan && manualPlan.places && manualPlan.places.length > 0 ? (
        <div className="space-y-4 mb-8">
          {(() => {
            const grouped = manualPlan.places.reduce((acc, item) => {
              if (!acc[item.dayNumber]) acc[item.dayNumber] = []
              acc[item.dayNumber].push(item)
              return acc
            }, {} as Record<number, typeof manualPlan.places>)
            
            return Object.entries(grouped).map(([day, items]) => (
              <Card key={day} className="p-5">
                <h3 className="font-bold text-primary-600 mb-3">Day {day}</h3>
                <div className="space-y-2">
                  {items.map((item, idx) => (
                    <div key={idx} className="p-3 bg-slate-50 rounded-xl">
                      <Link to={`/explore/${item.placeId}`} className="font-medium text-sm hover:text-primary-600">
                        {item.placeName}
                      </Link>
                    </div>
                  ))}
                </div>
              </Card>
            ))
          })()}
        </div>
      ) : (
        <Card className="p-8 text-center text-slate-500">
          No itinerary details available for this plan.
        </Card>
      )}

      <Link to={`/bookings/create?planId=${id}&type=${planType}`}>
        <Button className="w-full" size="lg">
          Book a Guide for This Plan
        </Button>
      </Link>
    </div>
  )
}