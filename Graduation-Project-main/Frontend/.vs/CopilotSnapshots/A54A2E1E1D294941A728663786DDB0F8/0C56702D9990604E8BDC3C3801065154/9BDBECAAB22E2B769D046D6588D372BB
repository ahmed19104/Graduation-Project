import { useEffect, useRef, useState } from 'react'
import { Camera, Plus, Trash2, Heart, Eye } from 'lucide-react'
import { storiesApi } from '@/api/stories'
import { Button, Card, EmptyState, ListSkeleton, Modal, Input, Textarea, useToast } from '@/components/ui'
import { getErrorMessage } from '@/api/axios'
import { formatRelativeTime } from '@/utils/format'
import type { Story } from '@/types'

export function GuideStoriesPage() {
  const [stories, setStories] = useState<Story[]>([])
  const [isLoading, setIsLoading] = useState(true)
  const [isUploading, setIsUploading] = useState(false)
  const [showModal, setShowModal] = useState(false)
  const [storyForm, setStoryForm] = useState({ city: '', description: '' })
  const [selectedFile, setSelectedFile] = useState<File | null>(null)
  const fileRef = useRef<HTMLInputElement>(null)
  const { showToast } = useToast()

  const loadStories = async () => {
    setIsLoading(true)
    try {
      const data = await storiesApi.getActiveStories()
      const myStories = data.filter(s => s.userId === localStorage.getItem('userId'))
      setStories(myStories)
    } catch (err) {
      showToast(getErrorMessage(err), 'error')
    } finally {
      setIsLoading(false)
    }
  }

  useEffect(() => {
    loadStories()
  }, [])

  const handleFileSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0]
    if (file) {
      setSelectedFile(file)
      setShowModal(true)
    }
  }

  const handleCreateStory = async () => {
    if (!selectedFile) {
      showToast('Please select a media file', 'error')
      return
    }
    
    if (!storyForm.city.trim()) {
      showToast('Please enter a city', 'error')
      return
    }
    
    if (!storyForm.description.trim()) {
      showToast('Please enter a description', 'error')
      return
    }
    
    setIsUploading(true)
    try {
      await storiesApi.createStory({
        city: storyForm.city,
        description: storyForm.description,
        mediaFile: selectedFile
      })
      showToast('Story published successfully!', 'success')
      setShowModal(false)
      setStoryForm({ city: '', description: '' })
      setSelectedFile(null)
      loadStories()
    } catch (err) {
      showToast(getErrorMessage(err), 'error')
    } finally {
      setIsUploading(false)
    }
  }

  const handleDeleteStory = async (storyId: string) => {
    if (!confirm('Are you sure you want to delete this story?')) return
    try {
      await storiesApi.deleteStory(storyId)
      showToast('Story deleted', 'success')
      loadStories()
    } catch (err) {
      showToast(getErrorMessage(err), 'error')
    }
  }

  const getMediaType = (url: string): 'image' | 'video' => {
    return url.match(/\.(mp4|mov|webm|mkv)$/i) ? 'video' : 'image'
  }

  return (
    <div className="container mx-auto px-4 py-8">
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-2xl font-bold">My Stories</h1>
        <Button onClick={() => fileRef.current?.click()} isLoading={isUploading}>
          <Plus className="h-4 w-4 mr-1" />
          New Story
        </Button>
        <input 
          ref={fileRef} 
          type="file" 
          accept="image/*,video/*" 
          className="hidden" 
          onChange={handleFileSelect} 
        />
      </div>

      {isLoading ? (
        <ListSkeleton count={3} />
      ) : stories.length === 0 ? (
        <EmptyState
          icon={Camera}
          title="No stories yet"
          description="Share your travel experiences with travelers"
          actionLabel="Add Story"
          onAction={() => fileRef.current?.click()}
        />
      ) : (
        <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
          {stories.map((story) => {
            const isVideo = getMediaType(story.mediaUrl) === 'video'
            const fullUrl = `${import.meta.env.VITE_API_BASE_URL?.replace('/api', '') || 'http://localhost:5008'}${story.mediaUrl}`
            
            return (
              <Card key={story.storyId} className="overflow-hidden relative group" padding="none">
                <div className="aspect-[9/16] relative">
                  {isVideo ? (
                    <video src={fullUrl} className="w-full h-full object-cover" />
                  ) : (
                    <img src={fullUrl} alt={story.description} className="w-full h-full object-cover" />
                  )}
                  <div className="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-4">
                    <div className="text-white text-center">
                      <div className="flex items-center justify-center gap-2">
                        <Eye className="h-4 w-4" />
                        <span className="text-xs">{story.viewsCount}</span>
                        <Heart className="h-4 w-4 ml-2" />
                        <span className="text-xs">{story.lovesCount}</span>
                      </div>
                    </div>
                  </div>
                  <button
                    type="button"
                    onClick={() => handleDeleteStory(story.storyId)}
                    className="absolute top-2 right-2 p-1.5 rounded-full bg-red-500 text-white opacity-0 group-hover:opacity-100 transition-opacity"
                  >
                    <Trash2 className="h-4 w-4" />
                  </button>
                </div>
                <div className="p-2">
                  <p className="text-xs font-medium truncate">{story.city}</p>
                  <p className="text-xs text-slate-500">{formatRelativeTime(story.createdAt)}</p>
                </div>
              </Card>
            )
          })}
        </div>
      )}

      {/* Create Story Modal */}
      <Modal
        isOpen={showModal}
        onClose={() => {
          setShowModal(false)
          setSelectedFile(null)
          setStoryForm({ city: '', description: '' })
        }}
        title="Create New Story"
      >
        <div className="space-y-4">
          {selectedFile && (
            <div className="bg-slate-100 rounded-lg p-2">
              {selectedFile.type.startsWith('video/') ? (
                <video src={URL.createObjectURL(selectedFile)} className="w-full max-h-48 object-cover rounded" controls />
              ) : (
                <img src={URL.createObjectURL(selectedFile)} alt="Preview" className="w-full max-h-48 object-cover rounded" />
              )}
            </div>
          )}
          
          <Input
            label="City *"
            value={storyForm.city}
            onChange={(e) => setStoryForm({ ...storyForm, city: e.target.value })}
            placeholder="e.g., Luxor, Cairo, Aswan"
            required
          />
          
          <Textarea
            label="Description *"
            value={storyForm.description}
            onChange={(e) => setStoryForm({ ...storyForm, description: e.target.value })}
            placeholder="Share what's happening..."
            rows={3}
            required
          />
          
          <div className="flex gap-2 justify-end">
            <Button variant="outline" onClick={() => setShowModal(false)}>Cancel</Button>
            <Button onClick={handleCreateStory} isLoading={isUploading}>Publish Story</Button>
          </div>
        </div>
      </Modal>
    </div>
  )
}