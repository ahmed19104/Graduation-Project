import { useEffect, useState } from 'react'
import { Wallet, TrendingUp, CreditCard, ArrowUpRight, Clock, AlertCircle } from 'lucide-react'
import { guidesApi } from '@/api/guides'
import { paymentsApi } from '@/api/payments'
import { Button, Card, Input, useToast } from '@/components/ui'
import { getErrorMessage } from '@/api/axios'
import { formatCurrency } from '@/utils/format'
import type { GuideWallet } from '@/types'

interface PaymentRecord {
  id: string
  amount: number
  method: string
  date: string
  status: 'completed' | 'pending'
}

export function GuideWalletPage() {
  const [wallet, setWallet] = useState<GuideWallet | null>(null)
  const [isLoading, setIsLoading] = useState(true)
  const [isPaying, setIsPaying] = useState(false)
  const [paymentAmount, setPaymentAmount] = useState('')
  const [paymentMethod, setPaymentMethod] = useState<'card' | 'bank'>('card')
  const { showToast } = useToast()

  const loadWallet = async () => {
    setIsLoading(true)
    try {
      const data = await guidesApi.getWallet()
      setWallet(data)
    } catch (err) {
      showToast(getErrorMessage(err), 'error')
    } finally {
      setIsLoading(false)
    }
  }

  useEffect(() => {
    loadWallet()
  }, [])

  const handlePayment = async () => {
    const amount = parseFloat(paymentAmount)
    if (isNaN(amount) || amount <= 0) {
      showToast('Please enter a valid amount', 'error')
      return
    }
    
    if (wallet && amount > wallet.outstandingBalance) {
      showToast(`Amount cannot exceed outstanding balance of ${formatCurrency(wallet.outstandingBalance)}`, 'error')
      return
    }
    
    setIsPaying(true)
    try {
      const result = await paymentsApi.payDues({
        amount: amount,
        payMethod: paymentMethod === 'card' ? 'Credit Card' : 'Bank Transfer'
      })
      
      showToast(result.message || 'Payment successful!', 'success')
      setPaymentAmount('')
      loadWallet()
    } catch (err) {
      showToast(getErrorMessage(err), 'error')
    } finally {
      setIsPaying(false)
    }
  }

  if (isLoading) {
    return (
      <div className="container mx-auto px-4 py-8 max-w-lg">
        <div className="text-center">Loading wallet data...</div>
      </div>
    )
  }

  const outstandingBalance = wallet?.outstandingBalance || 0
  const walletBalance = wallet?.walletBalance || 0
  const completedTours = wallet?.completedTours || 0
  const cancellationStrikes = wallet?.cancellationStrikes || 0
  const isSuspended = wallet?.isSuspended || false
  const hasDebt = outstandingBalance > 0

  return (
    <div className="container mx-auto px-4 py-8 max-w-lg">
      <h1 className="text-2xl font-bold mb-6">Wallet & Payments</h1>

      {/* Suspension Warning */}
      {isSuspended && (
        <Card className="mb-6 p-4 bg-red-50 border-red-200">
          <div className="flex items-center gap-2 text-red-600">
            <AlertCircle className="h-5 w-5" />
            <span className="font-semibold">Account Suspended</span>
          </div>
          <p className="text-sm text-red-600 mt-1">
            Your account has been suspended due to unpaid dues. Please settle your outstanding balance.
          </p>
        </Card>
      )}

      {/* Balance Cards */}
      <div className="grid grid-cols-2 gap-4 mb-6">
        <Card className={`bg-gradient-to-br from-primary-600 to-primary-800 text-white ${hasDebt ? '' : 'opacity-75'}`}>
          <Wallet className="h-6 w-6 mb-2 opacity-80" />
          <p className="text-xs opacity-80">Outstanding Balance</p>
          <p className="text-2xl font-bold mt-1">{formatCurrency(outstandingBalance)}</p>
          {hasDebt && <p className="text-xs opacity-70 mt-1">Due to platform</p>}
        </Card>
        
        <Card>
          <TrendingUp className="h-6 w-6 mb-2 text-emerald-500" />
          <p className="text-xs text-slate-500">Wallet Balance</p>
          <p className="text-2xl font-bold mt-1 text-emerald-600">{formatCurrency(walletBalance)}</p>
          <p className="text-xs text-slate-400 mt-1">Available for withdrawal</p>
        </Card>
      </div>

      {/* Stats */}
      <div className="grid grid-cols-2 gap-4 mb-6">
        <Card className="text-center">
          <p className="text-2xl font-bold">{completedTours}</p>
          <p className="text-xs text-slate-500">Completed Tours</p>
        </Card>
        <Card className={`text-center ${cancellationStrikes >= 3 ? 'bg-amber-50' : ''}`}>
          <p className={`text-2xl font-bold ${cancellationStrikes >= 3 ? 'text-amber-600' : ''}`}>
            {cancellationStrikes}/3
          </p>
          <p className="text-xs text-slate-500">Cancellation Strikes</p>
        </Card>
      </div>

      {/* Payment Section */}
      {hasDebt && (
        <Card className="p-5 mb-6">
          <h2 className="font-semibold mb-4 flex items-center gap-2">
            <CreditCard className="h-5 w-5 text-primary-600" />
            Pay Outstanding Dues
          </h2>
          
          <div className="space-y-4">
            <div>
              <label className="text-sm font-medium mb-1 block">Payment Method</label>
              <div className="flex gap-3">
                <button
                  type="button"
                  onClick={() => setPaymentMethod('card')}
                  className={`flex-1 py-2 px-3 rounded-xl border-2 text-sm font-medium transition-colors ${
                    paymentMethod === 'card'
                      ? 'border-primary-500 bg-primary-50 text-primary-700'
                      : 'border-slate-200 text-slate-500'
                  }`}
                >
                  Credit Card
                </button>
                <button
                  type="button"
                  onClick={() => setPaymentMethod('bank')}
                  className={`flex-1 py-2 px-3 rounded-xl border-2 text-sm font-medium transition-colors ${
                    paymentMethod === 'bank'
                      ? 'border-primary-500 bg-primary-50 text-primary-700'
                      : 'border-slate-200 text-slate-500'
                  }`}
                >
                  Bank Transfer
                </button>
              </div>
            </div>
            
            <Input
              label="Amount (EGP)"
              type="number"
              min={1}
              max={outstandingBalance}
              value={paymentAmount}
              onChange={(e) => setPaymentAmount(e.target.value)}
              placeholder={`Max ${formatCurrency(outstandingBalance)}`}
            />
            
            <Button 
              onClick={handlePayment} 
              isLoading={isPaying}
              disabled={!paymentAmount || parseFloat(paymentAmount) <= 0}
              className="w-full"
            >
              Pay {paymentAmount ? formatCurrency(parseFloat(paymentAmount)) : ''}
            </Button>
          </div>
        </Card>
      )}

      {/* Info Card */}
      <Card className="p-5 bg-slate-50">
        <h3 className="font-semibold mb-2 flex items-center gap-2">
          <Clock className="h-4 w-4" />
          Payment Information
        </h3>
        <ul className="text-xs text-slate-500 space-y-1 list-disc list-inside">
          <li>5% commission is deducted from each completed tour</li>
          <li>Outstanding balance must be paid within 30 days</li>
          <li>After 30 days, your account may be suspended</li>
          <li>Once suspended, you cannot accept new bookings</li>
          <li>Your account is reactivated automatically after full payment</li>
        </ul>
      </Card>
    </div>
  )
}